<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bobina_form" model="ir.ui.view">
        <field name="name">bobina.form</field>
        <field name="model">impresion.bobina</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" placeholder="Ej. PLA Rojo Mate"/>
                        <field name="material"/>
                        <field name="peso_inicial"/>
                        <field name="impresora_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bobina_tree" model="ir.ui.view">
        <field name="name">bobina.tree</field>
        <field name="model">impresion.bobina</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="material"/>
                <field name="peso_inicial"/>
                <field name="impresora_id"/>
            </list>
        </field>
    </record>

    <record id="action_gestion_bobinas" model="ir.actions.act_window">
        <field name="name">Bobinas de Filamento</field>
        <field name="res_model">impresion.bobina</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_bobinas_list" 
              name="Bobinas" 
              parent="menu_gestion_impresoras_root" 
              action="action_gestion_bobinas" 
              sequence="20"/>
</odoo>