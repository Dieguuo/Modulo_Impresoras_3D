<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_impresora_form" model="ir.ui.view">
        <field name="name">impresora.form</field>
        <field name="model">impresion.impresora</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="estado" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="foto" widget="image" class="oe_avatar" options="{'preview_image': 'foto'}"/>
                    
                    <div class="oe_title">
                        <label for="name" string="Nombre de la Impresora"/>
                        <h1><field name="name" placeholder="Ej. Ender 3 Pro"/></h1>
                    </div>
                    <group>
                        <group string="Información Técnica">
                            <field name="modelo"/>
                            <field name="tecnologia"/>
                        </group>
                        <group string="Uso e Inventario">
                            <field name="fecha_compra"/>
                            <field name="num_impresiones"/>
                            <field name="necesita_mantenimiento" 
                                   invisible="not necesita_mantenimiento" 
                                   widget="boolean_toggle" 
                                   readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_impresora_kanban" model="ir.ui.view">
        <field name="name">impresora.kanban</field>
        <field name="model">impresion.impresora</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado" class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex">
                            <div class="o_kanban_image me-3">
                                <field name="foto" widget="image" options="{'background': true, 'prevent_click': true}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="fw-bold fs-5">
                                    <field name="name"/>
                                </div>
                                <div class="text-muted">
                                    <field name="modelo"/>
                                </div>
                                <hr class="my-1"/>
                                <div>
                                    <strong>Tecnología: </strong><field name="tecnologia"/>
                                </div>
                                <div>
                                    <strong>Impresiones: </strong><field name="num_impresiones"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_impresora_tree" model="ir.ui.view">
        <field name="name">impresora.tree</field>
        <field name="model">impresion.impresora</field>
        <field name="arch" type="xml">
            <list>
                <field name="foto" widget="image" options="{'size': [30, 30]}" nolabel="1"/>
                <field name="name"/>
                <field name="modelo"/>
                <field name="tecnologia"/>
                <field name="num_impresiones" sum="Total Global"/>
                <field name="necesita_mantenimiento" widget="boolean_favorite" nolabel="1"/>
                <field name="estado" widget="badge" 
                       decoration-success="estado == 'disponible'" 
                       decoration-info="estado == 'imprimiendo'" 
                       decoration-danger="estado == 'averiada'"/>
            </list>
        </field>
    </record>

    <record id="view_impresora_search" model="ir.ui.view">
        <field name="name">impresora.search</field>
        <field name="model">impresion.impresora</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="modelo"/>
                <filter string="Disponibles" name="filter_disponible" domain="[('estado', '=', 'disponible')]"/>
                <filter string="En Reparación" name="filter_averiada" domain="[('estado', '=', 'averiada')]"/>
                <separator/>
                <filter string="Requiere SAT" name="filter_mantenimiento" domain="[('necesita_mantenimiento', '=', True)]"/>
                </search>
        </field>
    </record>

    <record id="action_gestion_impresoras" model="ir.actions.act_window">
        <field name="name">Impresoras 3D</field>
        <field name="res_model">impresion.impresora</field>
        <field name="view_mode">kanban,list,graph,form</field> 
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registra tu primera impresora 3D
            </p>
        </field>
    </record>

    <menuitem id="menu_gestion_impresoras_root" name="Impresoras 3D" sequence="10"/>
    <menuitem id="menu_impresoras_list" name="Inventario" 
              parent="menu_gestion_impresoras_root" 
              action="action_gestion_impresoras" sequence="10"/>

</odoo>